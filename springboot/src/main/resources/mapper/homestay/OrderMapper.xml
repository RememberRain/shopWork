<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.homestay.mapper.OrderMapper">

    <resultMap type="Order" id="OrderResult">
        <result property="orderId" column="order_id"/>
        <result property="homestayId" column="homestay_id"/>
        <result property="quantity" column="quantity"/>
        <result property="shippingAddress" column="shipping_address"/>
        <result property="totalPrice" column="total_price"/>
        <result property="contactPhone" column="contact_phone"/>
        <result property="status" column="status"/>
        <result property="commentStatus" column="comment_status"/>
        <result property="userId" column="user_id"/>
        <result property="createTime" column="create_time"/>
        <result property="title" column="title"/>
        <result property="image" column="image"/>
        <result property="address" column="address"/>
        <result property="userName" column="user_name"/>
        <result property="merchantUserId" column="merchantUserId"/>
    </resultMap>

    <select id="selectOrderList" parameterType="Order" resultMap="OrderResult">
        select o.order_id, o.homestay_id, o.quantity, o.shipping_address,
        o.total_price, o.contact_phone, o.status, o.comment_status, o.user_id, o.create_time,
        h.title, h.image, h.address, h.user_id as merchantUserId,
        u.user_name
        from `order` o
        left join homestay h on o.homestay_id = h.homestay_id
        left join user u on o.user_id = u.user_id
        <where>
            <if test="orderId != null  and orderId != ''">and o.order_id = #{orderId}</if>
            <if test="homestayId != null  and homestayId != ''">and o.homestay_id = #{homestayId}</if>
            <if test="status != null  and status != ''">and o.status = #{status}</if>
            <if test="commentStatus != null  and commentStatus != ''">and o.comment_status = #{commentStatus}</if>
            <if test="userId != null ">and o.user_id = #{userId}</if>
            <if test="merchantUserId != null ">and h.user_id = #{merchantUserId}</if>
            <if test="title != null  and title != ''">
                and h.title like concat('%', #{title}, '%')
            </if>
            <if test="userName != null  and userName != ''">
                and u.user_name like concat('%', #{userName}, '%')
            </if>
        </where>
        order by o.create_time desc
    </select>

    <select id="selectOrderByOrderId" parameterType="String" resultMap="OrderResult">
        select order_id,
               homestay_id,
               quantity,
               shipping_address,
               total_price,
               contact_phone,
               status,
               comment_status,
               user_id,
               create_time
        from `order`
        where order_id = #{orderId}
    </select>

    <insert id="insertOrder" parameterType="Order">
        insert into `order`
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">order_id,</if>
            <if test="homestayId != null and homestayId != ''">homestay_id,</if>
            <if test="quantity != null">quantity,</if>
            <if test="shippingAddress != null and shippingAddress != ''">shipping_address,</if>
            <if test="totalPrice != null">total_price,</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="commentStatus != null and commentStatus != ''">comment_status,</if>
            <if test="userId != null">user_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="orderId != null and orderId != ''">#{orderId},</if>
            <if test="homestayId != null and homestayId != ''">#{homestayId},</if>
            <if test="quantity != null">#{quantity},</if>
            <if test="shippingAddress != null and shippingAddress != ''">#{shippingAddress},</if>
            <if test="totalPrice != null">#{totalPrice},</if>
            <if test="contactPhone != null and contactPhone != ''">#{contactPhone},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="commentStatus != null and commentStatus != ''">#{commentStatus},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateOrder" parameterType="Order">
        update `order`
        <set>
            <if test="homestayId != null and homestayId != ''">homestay_id = #{homestayId},</if>
            <if test="quantity != null">quantity = #{quantity},</if>
            <if test="shippingAddress != null and shippingAddress != ''">shipping_address = #{shippingAddress},</if>
            <if test="checkInDate != null">check_in_date = #{checkInDate},</if>
            <if test="checkOutDate != null">check_out_date = #{checkOutDate},</if>
            <if test="nights != null">nights = #{nights},</if>
            <if test="totalPrice != null">total_price = #{totalPrice},</if>
            <if test="contactPhone != null and contactPhone != ''">contact_phone = #{contactPhone},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="commentStatus != null">comment_status = #{commentStatus},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="paymentTime != null">payment_time = #{paymentTime},</if>
            <if test="deliveryTime != null">delivery_time = #{deliveryTime},</if>
            <if test="finishTime != null">finish_time = #{finishTime},</if>
        </set>
        where order_id = #{orderId}
    </update>

    <delete id="deleteOrderByOrderIds" parameterType="String">
        delete from `order` where order_id in
        <foreach item="orderId" collection="array" open="(" separator="," close=")">
            #{orderId}
        </foreach>
    </delete>
</mapper>
